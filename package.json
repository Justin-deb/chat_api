{
  "name": "chat_api",
  "version": "1.0.0",
  "description": "A TypeScript Express.js boilerplate generated by gen-express-cli.",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "imports": {
    "#src/*": "./dist/src/*"
  },
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc --project tsconfig.build.json",
    "start": "node dist/src/server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{js,ts,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,ts,json}\"",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:cov": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^5.1.0",
    "socket.io": "^4.8.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@types/express": "^5.0.3",
    "@types/node": "^24.9.1",
    "eslint": "^9.38.0",
    "tsx": "^4.20.6",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.11.0"
  }
}
